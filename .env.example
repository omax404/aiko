# Aiko Environment Variables
# Copy this file to .env and fill in your details

# (Optional) Telegram Bot token for mobile access
TELEGRAM_TOKEN=your_telegram_bot_token_here
MASTER_ID=your_telegram_user_id

# (Optional) Discord Bot token for server access
DISCORD_TOKEN=your_discord_bot_token_here

# (Optional) External APIs
API_KEY=your_openai_or_custom_key_here
DEEPSEEK_API_KEY=your_deepseek_key_here
GEMINI_API_KEY=your_gemini_key_here

# (Optional) Spotify Music Bridge
SPOTIFY_CLIENT_ID=your_spotify_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_secret_here
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback
